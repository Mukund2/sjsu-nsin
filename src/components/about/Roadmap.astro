---
import { Timeline } from "../ui/timeline";

const roadmapItems = [
  {
    date: "Fall 2026",
    title: "Speaker Series",
    description:
      "Defense-tech founders, intelligence community veterans, and policymakers share how technology is reshaping national security. Runs throughout the fall semester.",
  },
  {
    date: "Fall 2026",
    title: "Government & Industry Projects Begin",
    description:
      "Students get paired with defense companies and government agencies for hands-on project work. Modeled after Stanford's Gordian Knot Center programs. Runs fall and spring semesters.",
  },
  {
    date: "Year-round",
    title: "Policy & Strategy Discussions",
    description:
      "Interdisciplinary forums on AI governance, export controls, and national security strategy. Open to all majors — engineering, political science, business.",
  },
  {
    date: "Spring 2027",
    title: "Hackathon",
    description:
      "Build working prototypes for real Department of Defense challenge problems. Prepares students for Stanford's Hacking for Defense (H4D) program which runs every spring quarter.",
  },
  {
    date: "Spring 2027",
    title: "Speaker Series Continues",
    description:
      "Second semester of speaker events with a focus on defense innovation, venture capital in defense-tech, and career paths in national security.",
  },
];
---

<section class="py-24 md:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-4 md:px-8">
    <div class="mb-16">
      <h2 class="text-3xl md:text-4xl font-display text-near-black">
        Throughout the year
      </h2>
      <p class="mt-4 text-mid-gray text-lg max-w-xl leading-relaxed">
        Programs run across fall and spring semesters, with policy discussions year-round.
      </p>
    </div>

    <Timeline client:visible items={roadmapItems} />
  </div>
</section>
