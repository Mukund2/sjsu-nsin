---
const navLinks = [
  { label: "About", href: "/about" },
  { label: "Join Us", href: "/#join-us" },
  { label: "Contact", href: "/contact" },
];

const currentPath = Astro.url.pathname;
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-light-gray">
  <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <img src="/logo.svg" alt="SJSU NSIN" class="h-14 w-auto" />
      <span class="text-[10px] uppercase tracking-[0.12em] text-near-black font-medium hidden sm:block leading-tight">
        National Security Innovation Network<br />
        <span class="text-mid-gray">at San Jose State University</span>
      </span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a
          href={link.href}
          target={link.href.startsWith("http") ? "_blank" : undefined}
          rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
          class:list={[
            "text-[13px] uppercase tracking-[0.15em] transition-colors duration-200",
            currentPath === link.href || currentPath === link.href + "/"
              ? "text-near-black font-medium"
              : "text-mid-gray hover:text-near-black"
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-near-black"
      aria-label="Toggle menu"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-light-gray bg-white">
    <div class="px-6 py-4 flex flex-col gap-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          target={link.href.startsWith("http") ? "_blank" : undefined}
          rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
          class="text-[13px] uppercase tracking-[0.15em] text-dark-gray hover:text-near-black transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<div class="h-16"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
