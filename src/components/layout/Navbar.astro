---
const navLinks = [
  { label: "About", href: "/about" },
  { label: "Join Us", href: "/#join-us" },
  { label: "Contact", href: "/contact" },
];

const currentPath = Astro.url.pathname;
---

<nav id="main-navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="w-full px-4 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3">
      <img src="/logo.svg" alt="SJSU NSIN" class="h-16 w-auto navbar-logo transition-all duration-300" />
      <span class="navbar-text text-[10px] uppercase tracking-[0.12em] font-medium hidden sm:block leading-tight transition-colors duration-300 text-white">
        National Security Innovation Network<br />
        <span class="navbar-subtext text-white/60 transition-colors duration-300">at San Jose State University</span>
      </span>
    </a>

    <div class="hidden md:flex items-center gap-8 pr-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          target={link.href.startsWith("http") ? "_blank" : undefined}
          rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
          class:list={[
            "navbar-link text-[13px] uppercase tracking-[0.15em] transition-colors duration-300",
            currentPath === link.href || currentPath === link.href + "/"
              ? "text-white font-medium"
              : "text-white/70 hover:text-white"
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 navbar-link text-white transition-colors duration-300"
      aria-label="Toggle menu"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-light-gray bg-white">
    <div class="px-6 py-4 flex flex-col gap-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          target={link.href.startsWith("http") ? "_blank" : undefined}
          rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
          class="text-[13px] uppercase tracking-[0.15em] text-dark-gray hover:text-near-black transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  const navbar = document.getElementById('main-navbar');

  function handleScroll() {
    if (!navbar) return;
    const scrolled = window.scrollY > 0;

    if (scrolled) {
      navbar.classList.add('bg-white/80', 'backdrop-blur-md', 'border-b', 'border-light-gray');
      navbar.querySelectorAll('.navbar-text').forEach(el => {
        el.classList.remove('text-white');
        el.classList.add('text-near-black');
      });
      navbar.querySelectorAll('.navbar-subtext').forEach(el => {
        el.classList.remove('text-white/60');
        el.classList.add('text-mid-gray');
      });
      navbar.querySelectorAll('.navbar-link').forEach(el => {
        el.classList.remove('text-white', 'text-white/70', 'hover:text-white');
        el.classList.add('text-mid-gray', 'hover:text-near-black');
      });
      navbar.querySelectorAll('.navbar-logo').forEach(el => {
        (el as HTMLElement).style.filter = 'none';
      });
    } else {
      navbar.classList.remove('bg-white/80', 'backdrop-blur-md', 'border-b', 'border-light-gray');
      navbar.querySelectorAll('.navbar-text').forEach(el => {
        el.classList.remove('text-near-black');
        el.classList.add('text-white');
      });
      navbar.querySelectorAll('.navbar-subtext').forEach(el => {
        el.classList.remove('text-mid-gray');
        el.classList.add('text-white/60');
      });
      navbar.querySelectorAll('.navbar-link').forEach(el => {
        el.classList.remove('text-mid-gray', 'hover:text-near-black');
        el.classList.add('text-white/70', 'hover:text-white');
      });
      navbar.querySelectorAll('.navbar-logo').forEach(el => {
        (el as HTMLElement).style.filter = 'invert(1) brightness(2)';
      });
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();
</script>
