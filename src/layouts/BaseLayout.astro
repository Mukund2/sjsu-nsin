---
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "SJSU National Security Innovation Network",
  description = "Applying innovation methodologies to national security challenges. A student organization at San Jose State University."
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="color-scheme" content="light" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/f117.jpg" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="SJSU NSIN" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/images/f117.jpg" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="apple-touch-icon" href="/images/f117.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
      referrerpolicy="no-referrer"
      crossorigin="anonymous"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-white">
    <Navbar />
    <main>
      <slot />
    </main>
  </body>
</html>
