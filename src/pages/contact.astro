---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact — SJSU NSIN">
  <section class="py-24 sm:py-32 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-16">
        <div class="md:col-span-5">
          <h1 class="text-4xl md:text-5xl font-display text-near-black mb-6">Get in touch</h1>
          <p class="text-mid-gray text-lg leading-relaxed mb-10">
            Interested in what we're building? Have a speaker suggestion or want
            to partner with us? Reach out through our socials or fill out the
            membership form.
          </p>

          <div class="space-y-6">
            <a
              href="https://www.instagram.com/sjsunsin/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 text-near-black hover:text-sjsu-blue transition-colors group"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C16.67.014 16.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
              <div>
                <p class="font-medium">Instagram</p>
                <p class="text-sm text-mid-gray">@sjsunsin</p>
              </div>
            </a>

            <a
              href="https://www.linkedin.com/company/sjsu-nsin/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 text-near-black hover:text-sjsu-blue transition-colors group"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              <div>
                <p class="font-medium">LinkedIn</p>
                <p class="text-sm text-mid-gray">SJSU NSIN</p>
              </div>
            </a>
          </div>

          <div class="mt-12 pt-8 border-t border-light-gray">
            <p class="text-sm text-mid-gray">
              San Jose State University<br />
              San Jose, CA 95192
            </p>
          </div>
        </div>

        <div class="md:col-span-6 md:col-start-7">
          <div class="relative overflow-hidden rounded-lg" style="height: 500px;">
            <img
              src="/images/rocket-launch.jpg"
              alt="SpaceX Falcon Heavy launch"
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-8 text-center">
              <h3 class="text-2xl font-display text-white mb-4">Ready to join?</h3>
              <a
                href="https://forms.gle/9MLweCMRaaTkrEkGA"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block bg-white text-near-black px-8 py-3 text-[13px] font-medium uppercase tracking-[0.15em] hover:bg-light-gray transition-colors"
              >
                Membership Form
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
